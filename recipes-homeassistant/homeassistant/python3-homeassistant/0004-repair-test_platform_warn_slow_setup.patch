From 7f69725170438d9c50ad0dceaa0bb10a2c720fd1 Mon Sep 17 00:00:00 2001
From: Tom Geelen <t.f.g.geelen@gmail.com>
Date: Sun, 7 Jun 2026 22:18:46 +0200
Subject: [PATCH] repair 0004-repair-test_platform_warn_slow_setup

This tests expected on very specific ordering of calls to the event loop's call_later method which can vary when tests run in different environments (for example under xdist / -n auto).
This patch updates the test to find the scheduled warning call for platform setup instead of relying on a fixed index.

Signed-off-by: Tom Geelen <t.f.g.geelen@gmail.com>
Upstream-Status: Inappropriate [OE specific]
---
 tests/helpers/test_entity_platform.py | 21 ++++++++++++++-------
 1 file changed, 14 insertions(+), 7 deletions(-)

diff --git a/tests/helpers/test_entity_platform.py b/tests/helpers/test_entity_platform.py
index dcc26db5ae7..a0716d4559c 100644
--- a/tests/helpers/test_entity_platform.py
+++ b/tests/helpers/test_entity_platform.py
@@ -283,14 +283,21 @@ async def test_platform_warn_slow_setup(hass: HomeAssistant) -> None:
         await hass.async_block_till_done()
         assert mock_call.called
 
-        # mock_calls[3] is the warning message for component setup
-        # mock_calls[10] is the warning message for platform setup
-        timeout, logger_method = mock_call.mock_calls[10][1][:2]
+        # Find the scheduled warning call for platform setup instead of
+        # relying on a fixed index which can vary when tests run in
+        # different environments (for example under xdist / -n auto).
+        found = False
+        for call in mock_call.mock_calls:
+            args = call[1]
+            if len(args) >= 2 and args[1] == _LOGGER.warning:
+                timeout = args[0]
+                assert timeout - hass.loop.time() == pytest.approx(
+                    entity_platform.SLOW_SETUP_WARNING, 0.5
+                )
+                found = True
+                break
 
-        assert timeout - hass.loop.time() == pytest.approx(
-            entity_platform.SLOW_SETUP_WARNING, 0.5
-        )
-        assert logger_method == _LOGGER.warning
+        assert found, "Did not find scheduled platform setup warning call"
 
         assert mock_call().cancel.called
 
